---
import SectionHeading from "@/components/SectionHeading.astro";
import { formatDate } from "@/lib/utils";
import type { BlogPost } from "@/types/content";

interface Props {
  blogs: BlogPost[];
  title?: string;
  limit?: number;
}

const { blogs, title = "Blogs", limit } = Astro.props;
const displayBlogs = typeof limit === "number" ? blogs.slice(0, limit) : blogs;
const showViewMore = typeof limit === "number" && blogs.length > limit;
---

<section class="py-12">
  <div class="section-shell">
    <SectionHeading title={title} />
    <div class="grid gap-6 lg:grid-cols-3">
      {displayBlogs.map((blog) => (
        <article class="bg-secondary border-border glow-panel overflow-hidden rounded-2xl border">
          <a href={`/blogs/${blog.slug}`}>
            <div class="bg-primary/60 flex aspect-[16/10] items-center justify-center overflow-hidden p-4">
              <img
                src={blog.coverImage || "https://images.unsplash.com/photo-1633356122544-f134324a6cee?w=1200&auto=format&fit=crop"}
                alt={blog.title}
                loading="lazy"
                decoding="async"
                width="1200"
                height="750"
                sizes="(min-width: 1024px) 22rem, (min-width: 768px) 50vw, calc(100vw - 3rem)"
                class="h-full w-full object-contain transition duration-300 hover:scale-[1.02]"
              />
            </div>
          </a>
          <div class="space-y-4 p-5">
            <p class="text-tertiary-content text-xs uppercase tracking-[0.24em]">{formatDate(blog.published)}</p>
            <h3 class="text-neutral text-xl font-semibold">
              <a href={`/blogs/${blog.slug}`}>{blog.title}</a>
            </h3>
            {blog.labels?.length ? (
              <div class="flex flex-wrap gap-2">
                {blog.labels.slice(0, 3).map((label) => <span class="pill text-accent text-xs">{label}</span>)}
                {blog.labels.length > 3 ? (
                  <span class="pill text-accent text-xs">+{blog.labels.length - 3} tags</span>
                ) : null}
              </div>
            ) : null}
          </div>
        </article>
      ))}
    </div>
    {showViewMore ? (
      <div class="mt-8 text-center">
        <a href="/blogs" class="text-accent text-sm font-medium">View More Blogs →</a>
      </div>
    ) : null}
  </div>
</section>
