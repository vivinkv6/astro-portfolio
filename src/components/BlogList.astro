---
import SectionHeading from "@/components/SectionHeading.astro";
import { excerpt, formatDate } from "@/lib/utils";
import type { BlogPost } from "@/types/content";

interface Props {
  blogs: BlogPost[];
  title?: string;
  limit?: number;
}

const { blogs, title = "Blogs", limit } = Astro.props;
const displayBlogs = typeof limit === "number" ? blogs.slice(0, limit) : blogs;
---

<section class="py-12">
  <div class="section-shell">
    <SectionHeading title={title} />
    <div class="grid gap-6 lg:grid-cols-3">
      {displayBlogs.map((blog) => (
        <article class="bg-secondary border-border glow-panel overflow-hidden rounded-2xl border">
          <a href={`/blogs/${blog.slug}`}>
            <div class="aspect-[16/10] overflow-hidden">
              <img src={blog.coverImage || "https://images.unsplash.com/photo-1633356122544-f134324a6cee?w=1200&auto=format&fit=crop"} alt={blog.title} class="h-full w-full object-cover transition duration-300 hover:scale-105" />
            </div>
          </a>
          <div class="space-y-4 p-5">
            <p class="text-tertiary-content text-xs uppercase tracking-[0.24em]">{formatDate(blog.published)}</p>
            <h3 class="text-neutral text-xl font-semibold">
              <a href={`/blogs/${blog.slug}`}>{blog.title}</a>
            </h3>
            <p class="text-tertiary-content text-sm leading-7">{excerpt(blog.content, 150)}</p>
            {blog.labels?.length ? (
              <div class="flex flex-wrap gap-2">
                {blog.labels.map((label) => <span class="pill text-accent text-xs">{label}</span>)}
              </div>
            ) : null}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
