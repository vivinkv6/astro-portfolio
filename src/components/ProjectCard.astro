---
import type { Project } from "@/types/content";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="bg-secondary border-border glow-panel overflow-hidden rounded-2xl border">
  <a href={`/projects/${project.slug}`} class="block">
    <div class="aspect-[16/10] overflow-hidden">
      <img src={project.cover} alt={project.title} class="h-full w-full object-cover transition duration-300 hover:scale-105" />
    </div>
  </a>
  <div class="space-y-4 p-5">
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="text-accent text-xs uppercase tracking-[0.24em]">{project.type}</p>
        <h3 class="text-neutral mt-2 text-xl font-semibold">{project.title}</h3>
      </div>
      {project.siteAge ? <span class="pill text-tertiary-content text-xs">{project.siteAge}</span> : null}
    </div>
    <p class="text-tertiary-content text-sm leading-7">{project.shortDescription}</p>
    {project.technologies?.length ? (
      <div class="flex flex-wrap gap-2">
        {project.technologies.map((tech) => <span class="pill text-primary-content text-xs">{tech}</span>)}
      </div>
    ) : null}
    <div class="flex flex-wrap gap-3 pt-2">
      <a href={`/projects/${project.slug}`} class="text-accent text-sm font-medium">View details</a>
      {project.livePreview ? (
        <a href={project.livePreview} target="_blank" rel="noreferrer" class="text-primary-content text-sm">Live preview</a>
      ) : null}
      {project.githubLink ? (
        <a href={project.githubLink} target="_blank" rel="noreferrer" class="text-primary-content text-sm">GitHub</a>
      ) : null}
    </div>
  </div>
</article>
