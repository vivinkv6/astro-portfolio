---
import type { Project } from "@/types/content";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="bg-secondary border-border glow-panel flex h-full flex-col overflow-hidden rounded-2xl border">
  <a href={`/project/${project.slug}`} class="block">
    <div class="bg-primary/40 border-border flex aspect-[16/10] items-center justify-center overflow-hidden border-b p-4">
      <img src={project.cover} alt={project.title} loading="lazy" decoding="async" class="h-full w-full object-contain transition duration-300 hover:scale-105" />
    </div>
  </a>
  <div class="flex h-full flex-col space-y-4 p-5">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h3 class="text-neutral text-xl font-semibold">{project.title}</h3>
        {project.technologies?.length ? (
          <div class="mt-3 flex flex-wrap gap-2">
            {project.technologies.map((tech) => (
              <div class="bg-primary/70 flex h-9 w-9 items-center justify-center rounded-lg p-1.5 shadow-sm">
                {tech.icon ? <img src={tech.icon} alt={tech.name} class="h-full w-full object-contain" /> : <span class="text-accent text-xs font-semibold">{tech.name.charAt(0)}</span>}
              </div>
            ))}
          </div>
        ) : null}
      </div>
      {project.siteAge ? <span class="pill text-tertiary-content text-xs">{project.siteAge}</span> : null}
    </div>
    <p class="text-tertiary-content text-sm leading-7">{project.shortDescription}</p>
    <div class="mt-auto pt-3">
      <a href={`/project/${project.slug}`} class="text-accent inline-flex items-center text-sm font-medium transition-transform duration-200 hover:translate-x-1">
        View details
      </a>
    </div>
  </div>
</article>
