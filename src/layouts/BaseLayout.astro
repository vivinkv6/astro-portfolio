---
import "@/styles/global.css";
import Footer from "@/components/Footer.astro";
import Navbar from "@/components/Navbar.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import { getEducationPageData, getExperiencePageData, getSiteConfig, getSkillsPageData } from "@/lib/content";
import { createPersonSchema, createWebsiteSchema } from "@/lib/schema";
import { normalizePath, siteUrl, toAbsoluteUrl } from "@/lib/utils";
import type { ThemeOption } from "@/types/content";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  preloadImage?: string;
  extraJs?: string;
  keywords?: string[];
  ogTitle?: string;
  ogDescription?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  robots?: string;
  mainClass?: string;
  hideFooter?: boolean;
  hideThemeToggle?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const [site, experiencePage, educationPage, skillsPage] = await Promise.all([
  getSiteConfig(),
  getExperiencePageData(),
  getEducationPageData(),
  getSkillsPageData()
]);
const {
  title = site.defaultSeo.title || `${site.personName} | ${site.jobTitle}`,
  description = site.defaultSeo.description || site.tagline,
  image = site.defaultSeo.ogImage || site.socialImage || "/assets/images/hero-image.png",
  preloadImage,
  extraJs,
  keywords,
  ogTitle = title,
  ogDescription = description,
  twitterTitle = ogTitle,
  twitterDescription = ogDescription,
  robots = "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1",
  mainClass = "min-h-screen",
  hideFooter = false,
  hideThemeToggle = false,
  structuredData = []
} = Astro.props;

function normalizeCanonical(pathname: string) {
  return toAbsoluteUrl(pathname);
}

const canonical = normalizeCanonical(Astro.url.pathname);
const socialImage = new URL(image, `${siteUrl}/`).toString();
const pathname = Astro.url.pathname;
const defaultTheme = site.themes.find((theme) => theme.isDefault)?.name || "dark";
const faviconUrl =
  site.favicon ||
  "https://res.cloudinary.com/dwwkqmedh/image/upload/v1772984186/favicon_2a1260f3bd.ico";

function normalizeSnippet(snippet?: string) {
  const content = snippet?.trim();
  if (!content) return null;

  return {
    content,
    isHtml: content.startsWith("<")
  };
}

function themeCss(theme: ThemeOption) {
  if (!theme.tokens) return "";

  return `[data-theme="${theme.name}"] {
  --p: ${theme.tokens.primary};
  --pc: ${theme.tokens.primaryContent};
  --s: ${theme.tokens.secondary};
  --sc: ${theme.tokens.secondaryContent};
  --tc: ${theme.tokens.tertiaryContent};
  --a: ${theme.tokens.accent};
  --n: ${theme.tokens.neutral};
  --b: ${theme.tokens.border};
  --marquee: ${theme.tokens.marquee};
  --gradient-start: ${theme.tokens.gradientStart};
  --gradient-mid: ${theme.tokens.gradientMid};
  --gradient-end: ${theme.tokens.gradientEnd};
}`;
}

const dynamicThemeCss = site.themes.map(themeCss).filter(Boolean).join("\n\n");
const themeInitScript = `(() => {
  const defaultTheme = ${JSON.stringify(defaultTheme)};
  const storedTheme = localStorage.getItem("theme") || defaultTheme;
  document.documentElement.setAttribute("data-theme", storedTheme);
})();`;
const linkNormalizationScript = `(() => {
  const normalizePath = (path) => {
    if (!path) return "/";
    const [pathnameWithSearch, hash = ""] = path.split("#");
    const [pathname = "/", search = ""] = pathnameWithSearch.split("?");
    const normalizedPathname = pathname === "/" ? "/" : pathname.replace(/\\/+$/, "") || "/";
    return normalizedPathname + (search ? "?" + search : "") + (hash ? "#" + hash : "");
  };
  const currentHost = window.location.hostname.toLowerCase();

  document.querySelectorAll("a[href]").forEach((anchor) => {
    const rawHref = anchor.getAttribute("href");
    if (!rawHref || rawHref.startsWith("#") || rawHref.startsWith("mailto:") || rawHref.startsWith("tel:")) {
      return;
    }

    if (rawHref.startsWith("/")) {
      anchor.setAttribute("href", normalizePath(rawHref));
      return;
    }

    try {
      const url = new URL(rawHref, window.location.origin);
      const incomingHost = url.hostname.toLowerCase();

      if (incomingHost === currentHost) {
        anchor.setAttribute("href", normalizePath((url.pathname || "/") + url.search + url.hash));
      }
    } catch {
      // Ignore malformed hrefs and leave them untouched.
    }
  });
})();`;
const headSnippet = normalizeSnippet(site.gtm?.headScript);
const otherHeadSnippet = normalizeSnippet(site.gtm?.otherScript);
const bodySnippet = normalizeSnippet(site.gtm?.bodyScript);
const extraSnippet = normalizeSnippet(extraJs);
const baseSchemas = [
  createWebsiteSchema(site),
  createPersonSchema(site, description, image, experiencePage.experiences, educationPage.items, skillsPage.categories)
];
const pageSchemas = Array.isArray(structuredData) ? structuredData : [structuredData];
const schemaGraph = [...baseSchemas, ...pageSchemas];
---

<!doctype html>
<html lang="en" data-theme={defaultTheme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    {keywords?.length ? <meta name="keywords" content={keywords.join(", ")} /> : null}
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={socialImage} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={twitterTitle} />
    <meta property="twitter:description" content={twitterDescription} />
    <meta property="twitter:image" content={socialImage} />
    <link rel="icon" type="image/x-icon" href={faviconUrl} />
    {preloadImage ? <link rel="preload" as="image" href={new URL(preloadImage, `${siteUrl}/`).toString()} /> : null}
    {dynamicThemeCss ? <style is:inline set:html={dynamicThemeCss}></style> : null}
    <script is:inline set:html={themeInitScript}></script>
    {headSnippet?.isHtml ? <Fragment set:html={headSnippet.content} /> : null}
    {headSnippet && !headSnippet.isHtml ? <script is:inline set:html={headSnippet.content}></script> : null}
    {otherHeadSnippet?.isHtml ? <Fragment set:html={otherHeadSnippet.content} /> : null}
    {otherHeadSnippet && !otherHeadSnippet.isHtml ? <script is:inline set:html={otherHeadSnippet.content}></script> : null}
    {extraSnippet?.isHtml ? <Fragment set:html={extraSnippet.content} /> : null}
    {extraSnippet && !extraSnippet.isHtml ? <script is:inline set:html={extraSnippet.content}></script> : null}
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaGraph)}></script>
  </head>
  <body>
    {bodySnippet?.isHtml ? <Fragment set:html={bodySnippet.content} /> : null}
    {bodySnippet && !bodySnippet.isHtml ? <script is:inline set:html={bodySnippet.content}></script> : null}
    <header>
      <Navbar pathname={pathname} navItems={site.headerLinks} siteName={site.siteName} />
    </header>
    <main class={mainClass}>
      <slot />
    </main>
    {hideThemeToggle ? null : <ThemeToggle themes={site.themes} defaultTheme={defaultTheme} />}
    {hideFooter ? null : <Footer site={site} />}
    <script is:inline set:html={linkNormalizationScript}></script>
  </body>
</html>
