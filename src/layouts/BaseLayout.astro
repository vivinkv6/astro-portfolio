---
import "@/styles/global.css";
import Footer from "@/components/Footer.astro";
import Navbar from "@/components/Navbar";
import ThemeToggle from "@/components/ThemeToggle";
import { getSiteConfig } from "@/lib/content";
import { siteUrl } from "@/lib/utils";
import type { ThemeOption } from "@/types/content";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  extraJs?: string;
  keywords?: string[];
  ogTitle?: string;
  ogDescription?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  robots?: string;
  mainClass?: string;
  hideFooter?: boolean;
  hideThemeToggle?: boolean;
}

const site = await getSiteConfig();
const {
  title = site.defaultSeo.title || `${site.personName} | ${site.jobTitle}`,
  description = site.defaultSeo.description || site.tagline,
  image = site.defaultSeo.ogImage || site.socialImage || "/assets/images/hero-image.png",
  extraJs,
  keywords,
  ogTitle = title,
  ogDescription = description,
  twitterTitle = ogTitle,
  twitterDescription = ogDescription,
  robots = "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1",
  mainClass = "min-h-screen",
  hideFooter = false,
  hideThemeToggle = false
} = Astro.props;

function normalizeCanonical(pathname: string) {
  const normalizedPath = pathname !== "/" ? pathname.replace(/\/+$/, "") : "";
  return new URL(normalizedPath || "/", siteUrl).toString().replace(/\/$/, normalizedPath ? "" : "/");
}

const canonical = normalizeCanonical(Astro.url.pathname);
const socialImage = new URL(image, siteUrl).toString();
const pathname = Astro.url.pathname;
const defaultTheme = site.themes.find((theme) => theme.isDefault)?.name || "dark";
const faviconUrl =
  site.favicon ||
  "https://res.cloudinary.com/dwwkqmedh/image/upload/v1772984186/favicon_2a1260f3bd.ico";

function themeCss(theme: ThemeOption) {
  if (!theme.tokens) return "";

  return `[data-theme="${theme.name}"] {
  --p: ${theme.tokens.primary};
  --pc: ${theme.tokens.primaryContent};
  --s: ${theme.tokens.secondary};
  --sc: ${theme.tokens.secondaryContent};
  --tc: ${theme.tokens.tertiaryContent};
  --a: ${theme.tokens.accent};
  --n: ${theme.tokens.neutral};
  --b: ${theme.tokens.border};
  --marquee: ${theme.tokens.marquee};
  --gradient-start: ${theme.tokens.gradientStart};
  --gradient-mid: ${theme.tokens.gradientMid};
  --gradient-end: ${theme.tokens.gradientEnd};
}`;
}

const dynamicThemeCss = site.themes.map(themeCss).filter(Boolean).join("\n\n");
const themeInitScript = `(() => {
  const defaultTheme = ${JSON.stringify(defaultTheme)};
  const storedTheme = localStorage.getItem("theme") || defaultTheme;
  document.documentElement.setAttribute("data-theme", storedTheme);
})();`;
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: site.personName,
  jobTitle: site.jobTitle,
  description,
  email: site.email,
  telephone: site.phone,
  address: {
    "@type": "PostalAddress",
    addressLocality: site.location,
    addressCountry: "IN"
  },
  url: siteUrl,
  image: socialImage
};
---

<!doctype html>
<html lang="en" data-theme={defaultTheme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    {keywords?.length ? <meta name="keywords" content={keywords.join(", ")} /> : null}
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={socialImage} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={twitterTitle} />
    <meta property="twitter:description" content={twitterDescription} />
    <meta property="twitter:image" content={socialImage} />
    <link rel="icon" type="image/x-icon" href={faviconUrl} />
    {dynamicThemeCss ? <style is:inline set:html={dynamicThemeCss}></style> : null}
    <script is:inline set:html={themeInitScript}></script>
    {site.gtm?.headScript ? <script is:inline set:html={site.gtm.headScript}></script> : null}
    {site.gtm?.otherScript ? <script is:inline set:html={site.gtm.otherScript}></script> : null}
    {extraJs ? <script is:inline set:html={extraJs}></script> : null}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;500;600;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)}></script>
  </head>
  <body>
    {site.gtm?.bodyScript ? <Fragment set:html={site.gtm.bodyScript} /> : null}
    <header>
      <Navbar pathname={pathname} navItems={site.headerLinks} siteName={site.siteName} client:load />
    </header>
    <main class={mainClass}>
      <slot />
    </main>
    {hideThemeToggle ? null : <ThemeToggle themes={site.themes} defaultTheme={defaultTheme} client:idle />}
    {hideFooter ? null : <Footer site={site} />}
  </body>
</html>
