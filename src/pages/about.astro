---
import AboutSection from "@/components/AboutSection.astro";
import SkillsStripExact from "@/components/SkillsStripExact";
import { getAboutPageData, getSiteConfig, getSkillsPageData } from "@/lib/content";
import { resolveSeo } from "@/lib/seo";
import BaseLayout from "@/layouts/BaseLayout.astro";

const [site, aboutPage, skillsPage] = await Promise.all([getSiteConfig(), getAboutPageData(), getSkillsPageData()]);
const seo = resolveSeo(site, aboutPage.seo, {
  title: "About | Vivin KV - Full-Stack Developer at SpiderWorks",
  description: aboutPage.content[0],
  image: aboutPage.image
});
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  image={seo.image}
  preloadImage={aboutPage.image}
  extraJs={seo.extraJs}
  keywords={seo.keywords}
>
  <AboutSection about={aboutPage} />
  <SkillsStripExact skills={skillsPage.categories.flatMap((category) => category.skills)} className="pt-8 pb-2" />
</BaseLayout>
