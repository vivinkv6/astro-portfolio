---
import AcademicsContentExact from "@/components/AcademicsContentExact";
import { getAcademicPageData, getSiteConfig } from "@/lib/content";
import { resolveSeo } from "@/lib/seo";
import BaseLayout from "@/layouts/BaseLayout.astro";

const [site, page] = await Promise.all([getSiteConfig(), getAcademicPageData()]);
const seo = resolveSeo(site, page.seo, {
  title: "Academics | Vivin KV - College Journey",
  description: "A chronicle of Vivin KV's academic journey at Sri C Achutha Menon Government College, including technical leadership at TinkerHub GCT, achievements, and memorable events."
});
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  image={seo.image}
  extraJs={seo.extraJs}
  keywords={seo.keywords}
>
  <section class="overflow-hidden py-16">
    <div class="mx-auto max-w-[1200px] px-4">
      <h2 class="text-neutral mb-12 text-3xl font-bold">
        <span class="text-accent mr-2">//</span>
        {page.pageHeading}
      </h2>
      <AcademicsContentExact journey={page.journey} client:load />
    </div>
  </section>
</BaseLayout>
