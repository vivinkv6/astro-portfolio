---
import { getAllBlogs, getBlogBySlug, getSiteConfig } from "@/lib/content";
import { createBlogPostingSchema, createBreadcrumbSchema } from "@/lib/schema";
import { resolveSeo } from "@/lib/seo";
import { excerpt, formatDate, normalizeRichTextHeadings, siteUrl } from "@/lib/utils";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const blogs = await getAllBlogs();
  return blogs.map((blog) => ({
    params: { slug: blog.slug },
    props: { blog }
  }));
}

const blog = Astro.props.blog ?? (await getBlogBySlug(Astro.params.slug!));

if (!blog) {
  return Astro.redirect("/blogs");
}

const site = await getSiteConfig();
const blogDescription = excerpt(blog.content, 155);
const normalizedBlogContentHtml = normalizeRichTextHeadings(blog.contentHtml);
const blogUrl = new URL(`/blogs/${blog.slug}`, siteUrl).toString();
const seo = resolveSeo(site, blog.seo, {
  title: `${blog.title} | ${site.personName}`,
  description: blogDescription,
  image: blog.bannerImage || blog.coverImage
});
const structuredData = [
  createBlogPostingSchema(blog),
  createBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Blogs", path: "/blogs" },
    { name: blog.title, path: `/blogs/${blog.slug}` }
  ])
];
---

<BaseLayout title={seo.title} description={seo.description} image={seo.image} extraJs={seo.extraJs} keywords={seo.keywords} structuredData={structuredData}>
  <article class="py-16">
    <div class="section-shell max-w-4xl">
      <header class="mb-8">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <a href="/blogs" class="text-accent text-sm">&larr; Back to blogs</a>
          <button
            type="button"
            class="bg-secondary text-neutral hover:text-accent inline-flex cursor-pointer items-center gap-2 rounded-full border border-white/10 px-3 py-2 text-xs font-medium transition-colors duration-200"
            data-share-button
            data-share-title={blog.title}
            data-share-text={blogDescription}
            data-share-url={blogUrl}
            aria-label={`Share ${blog.title}`}
          >
            <svg aria-hidden="true" viewBox="0 0 1024 1024" class="size-5 fill-current">
              <path d="M621.316 673.196c-44.684 0-81.386-30.167-82.155-70.263-0.132-6.992 1.967-14.055 3.526-21.003 0.536-2.383 0.596-3.605-2.115-4.915a30099.265 30099.265 0 0 1-119.489-57.887c-1.024-0.495-1.849-0.729-2.577-0.729-1.206 0-2.148 0.641-3.296 1.795-17.16 17.159-40.109 25.368-62.761 25.368-30.32 0-60.111-14.693-74.823-42.287-22.023-41.299 9.183-91.693 61.206-98.557 5.03-0.662 9.924-0.994 14.68-0.994 24.169 0 44.807 8.537 61.836 25.403 0.494 0.48 0.979 0.977 1.483 1.448 42.677-19.405 84.439-39.597 126.149-59.771-1.169-5.194-2.662-10.18-3.387-15.25-5.462-38.175 25.451-73.215 69.31-78.75 1.139-0.148 2.239-0.524 3.356-0.803h17.025c6.461 1.431 13.104 2.426 19.352 4.374 35.373 11.016 58.052 42.154 53.878 73.555-4.434 33.452-32.931 59.16-71.032 63.341-4.002 0.44-7.915 0.659-11.74 0.659-23.766 0-44.048-8.446-60.807-24.577-0.987-0.952-1.998-1.896-3.136-2.986-1.13 0.47-2.196 0.855-3.206 1.335-39.594 19.144-79.156 38.314-118.792 57.37-3.012 1.449-3.799 2.69-2.731 5.691 4.707 13.322 4.525 26.775-0.092 40.096-0.875 2.531-0.251 3.597 2.289 4.819a31968.752 31968.752 0 0 1 119.137 57.647c1.146 0.561 2.061 0.848 2.883 0.848 1.178 0 2.167-0.585 3.397-1.788 17.272-16.945 40.134-25.066 62.661-25.066 29.89 0.003 59.189 14.29 74.097 41.219 23.295 42.092-8.91 93.711-62.376 99.97-3.96 0.464-7.889 0.689-11.749 0.689zM352.773 425.817l-0.453 0.001c-30.876 0.183-56.024 22.173-55.904 48.877 0.131 26.806 25.271 48.596 56.358 48.684 0.243 0 0.482-0.003 0.723-0.004 30.514-0.345 55.484-22.293 55.414-48.917-0.06-26.601-24.947-48.302-55.479-48.638a58.299 58.299 0 0 0-0.659-0.003zM620.694 553.529l-0.362 0.001c-30.599 0.173-55.567 21.895-55.628 48.597-0.049 26.836 24.938 48.643 56.185 48.766 0.122 0 0.242-0.002 0.362-0.003 30.889-0.171 55.836-21.758 55.966-48.577 0.141-26.721-24.849-48.51-55.955-48.781l-0.568-0.003zM620.771 298.437c-31.008 0.061-55.997 21.718-56.056 48.403v0.631c0.201 26.614 25.124 48.166 55.723 48.333 0.12 0.002 0.24 0.003 0.674 0.001 31.066-0.148 56.044-21.817 56.105-48.65 0.059-26.763-25.021-48.55-55.955-48.717l-0.491-0.001z" />
            </svg>
            Share
          </button>
        </div>
        <time class="text-tertiary-content mt-5 block text-sm">{formatDate(blog.published)}</time>
        <h1 class="text-neutral mt-2 text-3xl font-bold md:text-4xl">{blog.title}</h1>
        <p class="text-tertiary-content mt-3 min-h-5 text-xs" data-share-feedback aria-live="polite"></p>
        {blog.labels?.length ? (
          <div class="mt-4 flex flex-wrap gap-2">
            {blog.labels.map((label) => <span class="pill text-accent text-xs">{label}</span>)}
          </div>
        ) : null}
      </header>

      <div class="bg-primary/60 overflow-hidden rounded-2xl p-2 sm:p-3 md:p-4">
        <img
          src={blog.bannerImage || blog.coverImage || "https://images.unsplash.com/photo-1633356122544-f134324a6cee?w=1200&auto=format&fit=crop"}
          alt={blog.title}
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="1200"
          height="675"
          sizes="(min-width: 1024px) 56rem, 100vw"
          class="max-h-[70vh] w-full rounded-xl object-contain sm:max-h-[32rem] md:max-h-[36rem]"
        />
      </div>

      {normalizedBlogContentHtml ? (
        <div class="rich-copy mt-12 space-y-6" set:html={normalizedBlogContentHtml}></div>
      ) : (
        <div class="rich-copy mt-12 space-y-10">
          {blog.sections?.map((section) => (
            <section class="space-y-5">
              {section.title ? <h2>{section.title}</h2> : null}
              {section.image ? (
                <div class="bg-primary/50 overflow-hidden rounded-2xl p-2 sm:p-3 md:p-4">
                  <img
                    src={section.image}
                    alt={section.title || blog.title}
                    loading="lazy"
                    decoding="async"
                    width="1200"
                    height="675"
                    sizes="(min-width: 1024px) 56rem, 100vw"
                    class="max-h-[65vh] w-full rounded-xl object-contain sm:max-h-[28rem] md:max-h-[32rem]"
                  />
                </div>
              ) : null}
              <div class="space-y-4" set:html={normalizeRichTextHeadings(section.contentHtml)}></div>
            </section>
          ))}
        </div>
      )}
    </div>
  </article>
</BaseLayout>

<script is:inline>
  const shareButton = document.querySelector('[data-share-button]');
  const shareFeedback = document.querySelector('[data-share-feedback]');

  if (shareButton instanceof HTMLButtonElement) {
    const setFeedback = (message) => {
      if (!(shareFeedback instanceof HTMLElement)) return;
      shareFeedback.textContent = message;
      window.clearTimeout(setFeedback.timeoutId);
      setFeedback.timeoutId = window.setTimeout(() => {
        shareFeedback.textContent = '';
      }, 2500);
    };

    setFeedback.timeoutId = 0;

    shareButton.addEventListener('click', async () => {
      const shareData = {
        title: shareButton.dataset.shareTitle || document.title,
        text: shareButton.dataset.shareText || '',
        url: shareButton.dataset.shareUrl || window.location.href,
      };

      try {
        if (navigator.share) {
          await navigator.share(shareData);
          return;
        }

        await navigator.clipboard.writeText(shareData.url);
        setFeedback('Link copied');
      } catch (error) {
        if (error instanceof DOMException && error.name === 'AbortError') return;
        setFeedback('Sharing is unavailable');
      }
    });
  }
</script>
