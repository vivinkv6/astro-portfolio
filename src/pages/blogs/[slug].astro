---
import { getAllBlogs, getBlogBySlug } from "@/lib/content";
import { formatDate } from "@/lib/utils";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const blogs = await getAllBlogs();
  return blogs.map((blog) => ({
    params: { slug: blog.slug },
    props: { blog }
  }));
}

const blog = Astro.props.blog ?? (await getBlogBySlug(Astro.params.slug!));

if (!blog) {
  return Astro.redirect("/blogs");
}
---

<BaseLayout title={`${blog.title} | Vivin KV`} description={blog.content}>
  <article class="py-16">
    <div class="section-shell max-w-4xl">
      <header class="mb-8">
        <a href="/blogs" class="text-accent text-sm">← Back to blogs</a>
        <time class="text-tertiary-content mt-5 block text-sm">{formatDate(blog.published)}</time>
        <h1 class="text-neutral mt-2 text-3xl font-bold md:text-4xl">{blog.title}</h1>
        {blog.labels?.length ? (
          <div class="mt-4 flex flex-wrap gap-2">
            {blog.labels.map((label) => <span class="pill text-accent text-xs">{label}</span>)}
          </div>
        ) : null}
      </header>

      <div class="overflow-hidden rounded-3xl">
        <img
          src={blog.coverImage || "https://images.unsplash.com/photo-1633356122544-f134324a6cee?w=1200&auto=format&fit=crop"}
          alt={blog.title}
          class="aspect-video w-full object-cover"
        />
      </div>

      <div class="rich-copy mt-12 space-y-6">
        <p>{blog.content}</p>
        <h2>Why It Matters</h2>
        <p>
          The Astro migration keeps this content presentation fast by default while still leaving room for Strapi-backed publishing and client-side interactivity only where it adds value.
        </p>
        <h2>Key Takeaways</h2>
        <ul>
          <li>Prefer static output for durable content pages.</li>
          <li>Keep JavaScript focused on truly interactive experiences.</li>
          <li>Preserve SEO and content structure during framework migrations.</li>
          <li>Use a clean data layer so local content and Strapi can coexist during transition.</li>
        </ul>
      </div>
    </div>
  </article>
</BaseLayout>
