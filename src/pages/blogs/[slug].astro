---
import { getAllBlogs, getBlogBySlug, getSiteConfig } from "@/lib/content";
import { createBlogPostingSchema, createBreadcrumbSchema } from "@/lib/schema";
import { resolveSeo } from "@/lib/seo";
import { excerpt, formatDate, normalizeRichTextHeadings } from "@/lib/utils";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const blogs = await getAllBlogs();
  return blogs.map((blog) => ({
    params: { slug: blog.slug },
    props: { blog }
  }));
}

const blog = Astro.props.blog ?? (await getBlogBySlug(Astro.params.slug!));

if (!blog) {
  return Astro.redirect("/blogs");
}

const site = await getSiteConfig();
const blogDescription = excerpt(blog.content, 155);
const normalizedBlogContentHtml = normalizeRichTextHeadings(blog.contentHtml);
const seo = resolveSeo(site, blog.seo, {
  title: `${blog.title} | ${site.personName}`,
  description: blogDescription,
  image: blog.bannerImage || blog.coverImage
});
const structuredData = [
  createBlogPostingSchema(blog),
  createBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Blogs", path: "/blogs" },
    { name: blog.title, path: `/blogs/${blog.slug}` }
  ])
];
---

<BaseLayout title={seo.title} description={seo.description} image={seo.image} extraJs={seo.extraJs} keywords={seo.keywords} structuredData={structuredData}>
  <article class="py-16">
    <div class="section-shell max-w-4xl">
      <header class="mb-8">
        <a href="/blogs" class="text-accent text-sm">&larr; Back to blogs</a>
        <time class="text-tertiary-content mt-5 block text-sm">{formatDate(blog.published)}</time>
        <h1 class="text-neutral mt-2 text-3xl font-bold md:text-4xl">{blog.title}</h1>
        {blog.labels?.length ? (
          <div class="mt-4 flex flex-wrap gap-2">
            {blog.labels.map((label) => <span class="pill text-accent text-xs">{label}</span>)}
          </div>
        ) : null}
      </header>

      <div class="overflow-hidden">
        <img
          src={blog.bannerImage || blog.coverImage || "https://images.unsplash.com/photo-1633356122544-f134324a6cee?w=1200&auto=format&fit=crop"}
          alt={blog.title}
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="1200"
          height="675"
          class="aspect-video w-full object-cover"
        />
      </div>

      {normalizedBlogContentHtml ? (
        <div class="rich-copy mt-12 space-y-6" set:html={normalizedBlogContentHtml}></div>
      ) : (
        <div class="rich-copy mt-12 space-y-10">
          {blog.sections?.map((section) => (
            <section class="space-y-5">
              {section.title ? <h2>{section.title}</h2> : null}
              {section.image ? (
                <img
                  src={section.image}
                  alt={section.title || blog.title}
                  loading="lazy"
                  decoding="async"
                  width="1200"
                  height="675"
                  class="aspect-video w-full object-cover"
                />
              ) : null}
              <div class="space-y-4" set:html={normalizeRichTextHeadings(section.contentHtml)}></div>
            </section>
          ))}
        </div>
      )}
    </div>
  </article>
</BaseLayout>
