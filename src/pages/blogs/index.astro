---
import BlogList from "@/components/BlogList.astro";
import PaginationNav from "@/components/PaginationNav.astro";
import { createBreadcrumbSchema, createCollectionPageSchema, createItemListSchema } from "@/lib/schema";
import { BLOGS_PAGE_SIZE } from "@/lib/pagination-config";
import { getBlogPageData, getPaginatedBlogs, getSiteConfig } from "@/lib/content";
import { resolveSeo } from "@/lib/seo";
import { siteUrl } from "@/lib/utils";
import BaseLayout from "@/layouts/BaseLayout.astro";

const [site, page, paginatedBlogs] = await Promise.all([getSiteConfig(), getBlogPageData(), getPaginatedBlogs(1, BLOGS_PAGE_SIZE)]);
const seo = resolveSeo(site, page.seo, {
  title: "Blogs | Vivin KV - Tech Articles",
  description: "Read articles on web development, React, Next.js, TypeScript, and practical engineering workflows."
});
const structuredData = [
  createCollectionPageSchema({
    name: seo.title,
    description: seo.description,
    path: "/blogs"
  }),
  createItemListSchema({
    name: "Blog posts",
    path: "/blogs",
    items: paginatedBlogs.items,
    mapItem: (blog) => ({
      name: blog.title,
      url: new URL(`/blogs/${blog.slug}`, siteUrl).toString()
    })
  }),
  createBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Blogs", path: "/blogs" }
  ])
];
---

<BaseLayout title={seo.title} description={seo.description} image={seo.image} extraJs={seo.extraJs} keywords={seo.keywords} structuredData={structuredData}>
  <BlogList blogs={paginatedBlogs.items} title={page.pageHeading} />
  <PaginationNav basePath="/blogs" currentPage={paginatedBlogs.pagination.page} totalPages={paginatedBlogs.pagination.pageCount} />
</BaseLayout>
