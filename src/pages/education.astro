---
import EducationContentExact from "@/components/EducationContentExact";
import { getEducationPageData, getSiteConfig } from "@/lib/content";
import { resolveSeo } from "@/lib/seo";
import BaseLayout from "@/layouts/BaseLayout.astro";

const [site, page] = await Promise.all([getSiteConfig(), getEducationPageData()]);
const seo = resolveSeo(site, page.seo, {
  title: "Education | Vivin KV - Academic Background",
  description: "Vivin KV's educational background includes BSc Computer Science from Sri C Achutha Menon Government College Thrissur (2021-2024) and Commerce from CNN Higher Secondary School (2019-2021)."
});
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  image={seo.image}
  extraJs={seo.extraJs}
  keywords={seo.keywords}
>
  <section class="overflow-hidden py-16">
    <div class="mx-auto max-w-[1200px] px-4">
      <h2 class="text-neutral mb-12 text-3xl font-bold">
        <span class="text-accent mr-2">//</span>
        {page.pageHeading}
      </h2>
      <EducationContentExact items={page.items} client:visible />
    </div>
  </section>
</BaseLayout>
