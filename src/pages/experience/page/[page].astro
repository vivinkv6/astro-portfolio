---
import ExperienceSectionExact from "@/components/ExperienceSectionExact";
import PaginationNav from "@/components/PaginationNav.astro";
import { getExperiencePageData, getPaginatedExperiences, getSiteConfig } from "@/lib/content";
import { EXPERIENCES_PAGE_SIZE } from "@/lib/pagination-config";
import { resolveSeo } from "@/lib/seo";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const firstPage = await getPaginatedExperiences(1, EXPERIENCES_PAGE_SIZE);

  return Array.from({ length: Math.max(0, firstPage.pagination.pageCount - 1) }, (_, index) => {
    const page = index + 2;
    return {
      params: { page: String(page) }
    };
  });
}

const currentPage = Number(Astro.params.page || "1");
const [site, pageData, paginatedExperiences] = await Promise.all([
  getSiteConfig(),
  getExperiencePageData(),
  getPaginatedExperiences(currentPage, EXPERIENCES_PAGE_SIZE)
]);
const seo = resolveSeo(site, pageData.seo, {
  title: `${pageData.pageHeading} | Page ${currentPage} | Vivin KV`,
  description: "Professional experience across frontend development, API integration, and technical leadership."
});
---

<BaseLayout title={seo.title} description={seo.description} image={seo.image} extraJs={seo.extraJs} keywords={seo.keywords}>
  <ExperienceSectionExact experiences={paginatedExperiences.items} title={pageData.pageHeading} client:load />
  <PaginationNav basePath="/experience" currentPage={paginatedExperiences.pagination.page} totalPages={paginatedExperiences.pagination.pageCount} />
</BaseLayout>
