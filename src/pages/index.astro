---
import AboutSection from "@/components/AboutSection.astro";
import BlogList from "@/components/BlogList.astro";
import ExperienceSection from "@/components/ExperienceSection.astro";
import HeroExact from "@/components/HeroExact.astro";
import ProjectGrid from "@/components/ProjectGrid.astro";
import SkillsStripExact from "@/components/SkillsStripExact";
import { getAboutPageData, getAllBlogs, getAllProjects, getExperiencePageData, getHomePageData, getSiteConfig, getSkillsPageData } from "@/lib/content";
import { resolveSeo } from "@/lib/seo";
import BaseLayout from "@/layouts/BaseLayout.astro";

const [site, homePage, aboutPage, experiencePage, skillsPage, projects, blogs] = await Promise.all([
  getSiteConfig(),
  getHomePageData(),
  getAboutPageData(),
  getExperiencePageData(),
  getSkillsPageData(),
  getAllProjects(),
  getAllBlogs()
]);
const seo = resolveSeo(site, homePage.seo, {
  title: `${site.personName} | Full-Stack Developer in Kerala, India`,
  description: site.tagline,
  image: homePage.hero.image
});
---

<BaseLayout title={seo.title} description={seo.description} image={seo.image} extraJs={seo.extraJs} keywords={seo.keywords}>
  <HeroExact hero={homePage.hero} />
  <SkillsStripExact skills={skillsPage.categories.flatMap((category) => category.skills)} />
  <AboutSection about={aboutPage} />
  <ExperienceSection experiences={experiencePage.experiences} limit={2} title={experiencePage.pageHeading} />
  <ProjectGrid projects={projects} limit={3} title="Latest Projects" />
  <BlogList blogs={blogs} limit={3} title="Latest Blogs" />
</BaseLayout>
