---
import ProjectGrid from "@/components/ProjectGrid.astro";
import PaginationNav from "@/components/PaginationNav.astro";
import { PROJECTS_PAGE_SIZE } from "@/lib/pagination-config";
import { getPaginatedProjects, getProjectPageData, getSiteConfig } from "@/lib/content";
import { createBreadcrumbSchema, createCollectionPageSchema, createItemListSchema } from "@/lib/schema";
import { resolveSeo } from "@/lib/seo";
import { siteUrl } from "@/lib/utils";
import BaseLayout from "@/layouts/BaseLayout.astro";

const [site, page, paginatedProjects] = await Promise.all([getSiteConfig(), getProjectPageData(), getPaginatedProjects(1, PROJECTS_PAGE_SIZE)]);
const seo = resolveSeo(site, page.seo, {
  title: "Project | Vivin KV - Portfolio",
  description: "Explore the portfolio projects, product experiments, and client work delivered by Vivin KV."
});
const structuredData = [
  createCollectionPageSchema({
    name: seo.title,
    description: seo.description,
    path: "/project"
  }),
  createItemListSchema({
    name: "Projects",
    path: "/project",
    items: paginatedProjects.items,
    mapItem: (project) => ({
      name: project.title,
      url: new URL(`/project/${project.slug}`, siteUrl).toString()
    })
  }),
  createBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Project", path: "/project" }
  ])
];
---

<BaseLayout title={seo.title} description={seo.description} image={seo.image} extraJs={seo.extraJs} keywords={seo.keywords} structuredData={structuredData}>
  <ProjectGrid projects={paginatedProjects.items} title={page.pageHeading} />
  <PaginationNav basePath="/project" currentPage={paginatedProjects.pagination.page} totalPages={paginatedProjects.pagination.pageCount} />
</BaseLayout>
