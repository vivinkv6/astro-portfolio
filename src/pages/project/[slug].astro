---
import { GithubIcon, PreviewIcon } from "@/utils/icons";
import { getAllProjects, getProjectBySlug, getProjectPageData, getSiteConfig } from "@/lib/content";
import { createBreadcrumbSchema, createSoftwareSourceCodeSchema } from "@/lib/schema";
import { formatDate, normalizeRichTextHeadings } from "@/lib/utils";
import { resolveSeo } from "@/lib/seo";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const projects = await getAllProjects();
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const project = Astro.props.project ?? (await getProjectBySlug(Astro.params.slug!));

if (!project) {
  return Astro.redirect("/project");
}

const [site, projectPage] = await Promise.all([getSiteConfig(), getProjectPageData()]);
const normalizedProjectContentHtml = normalizeRichTextHeadings(project.contentHtml);
const seo = resolveSeo(site, project.seo, {
  title: `${project.title} | ${site.personName}`,
  description: project.contentHtml ? project.contentHtml.replace(/<[^>]*>/g, "").slice(0, 155) : project.shortDescription,
  image: project.cover
});
const structuredData = [
  createSoftwareSourceCodeSchema(project),
  createBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Project", path: "/project" },
    { name: project.title, path: `/project/${project.slug}` }
  ])
];
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  image={seo.image}
  extraJs={seo.extraJs}
  keywords={seo.keywords}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  twitterTitle={seo.twitterTitle}
  twitterDescription={seo.twitterDescription}
  structuredData={structuredData}
>
  <article class="py-16">
    <div class="section-shell max-w-4xl">
      <header class="mb-8">
        <a href="/project" class="text-accent text-sm">&larr; Back to projects</a>
        <h1 class="text-neutral mt-2 text-3xl font-bold md:text-4xl">{project.title}</h1>
        {project.technologies?.length ? (
          <div class="mt-4 flex flex-wrap gap-2">
            {project.technologies.map((tech) => (
              <span class="bg-secondary border-border inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-xs">
                {tech.icon ? <img src={tech.icon} alt={tech.name} class="h-3.5 w-3.5 object-contain" /> : <span class="text-accent font-semibold">{tech.name.charAt(0)}</span>}
                <span class="text-primary-content">{tech.name}</span>
              </span>
            ))}
          </div>
        ) : null}
      </header>

      <div>
        <img
          src={project.cover}
          alt={project.title}
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="1200"
          height="675"
          sizes="(min-width: 1024px) 56rem, 100vw"
          class="max-h-[70vh] w-full object-contain sm:max-h-[32rem] md:max-h-[36rem]"
        />
      </div>

      {(project.livePreview || project.githubLink) ? (
        <div class="mt-8 flex flex-wrap gap-3">
          {project.livePreview ? (
            <a href={project.livePreview} target="_blank" rel="noreferrer" class="bg-accent inline-flex items-center gap-2 rounded-lg px-5 py-3 text-sm font-medium text-[#00071E]">
              <PreviewIcon className="h-4 w-4" />
              Live preview
            </a>
          ) : null}
          {project.githubLink ? (
            <a href={project.githubLink} target="_blank" rel="noreferrer" class="bg-secondary text-neutral border-border inline-flex items-center gap-2 rounded-lg border px-5 py-3 text-sm">
              <GithubIcon className="h-4 w-4" />
              GitHub
            </a>
          ) : null}
        </div>
      ) : null}

      {normalizedProjectContentHtml ? (
        <div class="rich-copy mt-12 space-y-6" set:html={normalizedProjectContentHtml}></div>
      ) : null}
    </div>
  </article>
</BaseLayout>
