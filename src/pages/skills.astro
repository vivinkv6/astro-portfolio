---
import SkillsContentExact from "@/components/SkillsContentExact";
import { getSiteConfig, getSkillsPageData } from "@/lib/content";
import { resolveSeo } from "@/lib/seo";
import BaseLayout from "@/layouts/BaseLayout.astro";

const [site, page] = await Promise.all([getSiteConfig(), getSkillsPageData()]);
const seo = resolveSeo(site, page.seo, {
  title: "Skills | Vivin KV - Technologies",
  description: "Vivin KV is proficient in Next.js, React.js, TypeScript, Node.js, Express.js, MongoDB, PostgreSQL, Tailwind CSS, Git, and more."
});
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  image={seo.image}
  extraJs={seo.extraJs}
  keywords={seo.keywords}
>
  <section class="overflow-hidden py-16">
    <div class="mx-auto max-w-[1200px] px-4">
      <h2 class="text-neutral mb-12 text-3xl font-bold">
        <span class="text-accent mr-2">//</span>
        {page.pageHeading}
      </h2>
      <SkillsContentExact categories={page.categories} client:visible />
    </div>
  </section>
</BaseLayout>
